    "randomPrompt.12" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Northern lights dancing over a frozen Icelandic lake, perfect mirror reflection, long exposure feel, magical night sky" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Северное сияние над замёрзшим исландским озером, идеальное зеркальное отражение, эффект длинной выдержки, волшебное ночное небо" } }
