    "randomPrompt.01" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "A cinematic shot of neon cyberpunk city streets under heavy rain, 8k resolution, volumetric lighting, hyper-realistic textures, synthwave color palette, anamorphic lens flare" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Кинематографичный кадр неоновых киберпанк-улиц под ливнем, 8k, объёмный свет, гиперреалистичные текстуры, синтвейв-палитра, анаморфный блик" } }
      }
    },
    "randomPrompt.02" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Ocean waves crashing on rocky shore at golden hour, slow-motion aerial drone shot, dramatic clouds, cinematic color grading" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Океанские волны разбиваются о скалистый берег на закате, медленная аэросъёмка с дрона, драматичные облака, кинематографичная цветокоррекция" } }
      }
    },
    "randomPrompt.03" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Luxury product rotating on a minimal white background, studio rim lighting, glossy reflections, commercial advertising style" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Премиальный продукт вращается на минималистичном белом фоне, студийный контровой свет, глянцевые блики, рекламный стиль" } }
      }
    },
    "randomPrompt.04" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "A majestic eagle soaring over snow-capped mountains, epic wide-angle lens, crisp alpine air, sun rays breaking through clouds" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Величественный орёл парит над заснеженными горами, эпический широкоугольный кадр, чистый горный воздух, солнечные лучи сквозь облака" } }
      }
    },
    "randomPrompt.05" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Cherry blossoms falling in a tranquil Japanese garden, soft morning light, shallow depth of field, poetic and serene atmosphere" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Лепестки сакуры падают в тихом японском саду, мягкий утренний свет, малая глубина резкости, поэтичная атмосфера" } }
      }
    },
    "randomPrompt.06" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Futuristic sports car speeding through a desert highway at sunset, heat haze, cinematic motion blur, orange and purple sky" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Футуристичный спорткар мчится по пустынной трассе на закате, марево жары, кинематографичное размытие движения, оранжево-фиолетовое небо" } }
      }
    },
    "randomPrompt.07" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Cozy coffee shop interior, steam rising from a ceramic cup, rain streaking down the window, warm amber tones, intimate mood" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Уютная кофейня, пар поднимается от керамической чашки, дождь стекает по окну, тёплые янтарные тона, интимное настроение" } }
      }
    },
    "randomPrompt.08" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Astronaut floating inside a space station, Earth visible through the viewport, realistic zero-gravity physics, sci-fi cinematic lighting" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Астронавт парит внутри космической станции, Земля видна в иллюминаторе, реалистичная невесомость, кинематографичный sci-fi свет" } }
      }
    },
    "randomPrompt.09" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Medieval castle on a cliff during a thunderstorm, lightning illuminating stone towers, dark fantasy atmosphere, dramatic wide shot" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Средневековый замок на скале во время грозы, молнии освещают каменные башни, тёмное фэнтези, драматичный широкий кадр" } }
      }
    },
    "randomPrompt.10" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Macro close-up of dew drops on flower petals, dreamy bokeh background, soft natural light, ultra-detailed textures" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Макросъёмка капель росы на лепестках цветка, мечтательный боке-фон, мягкий естественный свет, сверхдетальные текстуры" } }
      }
    },
    "randomPrompt.11" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Street dancer performing under a colorful graffiti wall, dynamic handheld camera, urban energy, high contrast lighting" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Уличный танцор выступает у яркой граффити-стены, динамичная камера с рук, городская энергия, контрастный свет" } }
      }
