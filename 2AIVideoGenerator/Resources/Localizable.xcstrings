    "randomPrompt.17" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Campfire crackling under a star-filled Milky Way sky, timelapse clouds, peaceful wilderness night, cinematic warmth" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Костёр потрескивает под звёздным небом Млечного Пути, таймлапс облаков, спокойная ночь в дикой природе, кинематографичное тепло" } }
