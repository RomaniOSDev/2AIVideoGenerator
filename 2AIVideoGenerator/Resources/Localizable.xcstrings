    "randomPrompt.14" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Luxury wristwatch rotating on black marble, dramatic spotlight, metallic gleam, high-end commercial macro shot" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Роскошные часы вращаются на чёрном мраморе, драматичный прожектор, металлический блеск, премиальная рекламная макросъёмка" } }
