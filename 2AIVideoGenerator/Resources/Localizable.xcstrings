    },
    "randomPrompt.13" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Vintage film style couple walking through a Parisian alley, soft film grain, romantic mood, warm afternoon sunlight" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Пара в винтажном киностиле идёт по парижскому переулку, мягкое плёночное зерно, романтичное настроение, тёплый дневной свет" } }
      }
