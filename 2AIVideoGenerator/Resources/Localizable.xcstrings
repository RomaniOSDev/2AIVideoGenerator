    "randomPrompt.16" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Humanoid robot assembling itself in a high-tech laboratory, blue holographic UI overlays, sleek sci-fi environment" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Гуманоидный робот собирает себя в высокотехнологичной лаборатории, голубые голографические интерфейсы, стильный sci-fi антураж" } }
