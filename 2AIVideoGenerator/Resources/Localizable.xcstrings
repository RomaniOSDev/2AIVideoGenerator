    "randomPrompt.15" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Tropical waterfall in a lush rainforest, mist and sun rays filtering through canopy, immersive nature documentary style" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Тропический водопад в джунглях, туман и солнечные лучи сквозь кроны, погружающий стиль природного документального кино" } }
